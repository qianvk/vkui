@PACKAGE_INIT@

include(CMakeFindDependencyMacro)
find_dependency(Qt6 6.6 REQUIRED COMPONENTS Core Gui Svg)

include("${CMAKE_CURRENT_LIST_DIR}/VkUICoreTargets.cmake")
set(VkUI_Core_FOUND TRUE)

if(NOT VkUI_FIND_COMPONENTS OR "Widgets" IN_LIST VkUI_FIND_COMPONENTS)
    find_dependency(Qt6 6.6 REQUIRED COMPONENTS Widgets)
    include("${CMAKE_CURRENT_LIST_DIR}/VkUIWidgetsTargets.cmake")
    set(VkUI_Widgets_FOUND TRUE)
endif()

check_required_components(VkUI)

